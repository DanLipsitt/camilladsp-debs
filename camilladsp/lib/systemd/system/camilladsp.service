[Unit]
Description=CamillaDSP Daemon
After=sound.target
StartLimitIntervalSec=10
StartLimitBurst=10

[Service]
Type=simple
ExecStart=/usr/local/bin/camilladsp -p 1234 -w -s /var/lib/camilladsp/statefile.yml /etc/camilladsp/config.yml
Restart=always
RestartSec=1
StandardOutput=journal
StandardError=journal
SyslogIdentifier=camilladsp
User=root
Group=audio
CPUSchedulingPolicy=fifo
CPUSchedulingPriority=10

[Install]
WantedBy=multi-user.target
